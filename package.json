{
  "name": "astro-loader-storyblok",
  "version": "1.0.17",
  "description": "Astro content loader for Storyblok",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "LICENSE.txt",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "dev": "tsc --watch",
    "debug:playground": "DEBUG=astro:loader-storyblok* pnpm --filter ./playground/minimal-astro-project dev",
    "debug:playground:force": "pnpm debug:playground --force",
    "prepublishOnly": "pnpm build",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "lint:markdown": "markdownlint-cli2 \"**/*.{md,mdx}\" \"!node_modules\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "version": "node ./scripts/increase-package-version.mjs",
    "version-minor": "pnpm run version minor"
  },
  "keywords": [
    "astro",
    "storyblok",
    "withastro",
    "astro-component",
    "astro-loader"
  ],
  "author": "Romain Pironneau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/romainpi/astro-loader-storyblok.git",
    "branch": "main"
  },
  "homepage": "https://github.com/romainpi/astro-loader-storyblok#readme",
  "bugs": {
    "url": "https://github.com/romainpi/astro-loader-storyblok/issues"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "^6.0.3"
      }
    }
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@github/markdownlint-github": "0.8.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "astro": "^6.1.9",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "happy-dom": "^20.9.0",
    "markdown-it": "14.1.1",
    "markdownlint-cli2": "0.22.1",
    "markdownlint-cli2-formatter-pretty": "0.0.10",
    "semver": "7.7.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@storyblok/js": "5.1.3",
    "@storyblok/management-api-client": "0.2.3"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  }
}
